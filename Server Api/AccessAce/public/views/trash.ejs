<%- include('partials/sidebar') %>
<%- include('partials/chatbot')%>

<div class="trash-page">
  <div class="header">
    <div class="left-header">
      <h2>Trash</h2>
      <p>Manage your deleted items. Restore or permanently delete them from here.</p>
    </div>
    <div class="right-header">
      <button class="clear-trash-btn">
        <i class="fa-solid fa-trash-can"></i> Clear Trash
      </button>
    </div>
  </div>

  <div class="trash-section">
    <% 
    const combinedItems = [
      ...clients.map(client => ({ type: 'client', ...client })),
      ...projects.map(project => ({ type: 'project', ...project }))
    ];

    if (combinedItems.length > 0) { 
    %> 
      <div class="trash-list">
        <% combinedItems.forEach(item => { %>
          <div class="trash-item">
            <div class="item-info">
              <i class="fa-solid <%= item.type === 'client' ? 'fa-user-circle' : 'fa-cogs' %>"></i>  
              <div class="item-name"><%= item.name %></div>
            </div>
            <div class="item-date">Deleted on <%= item.deleted_date %></div>
            <div class="item-actions">
              <button class="action-btn restore-btn" 
                      data-id="<%= item.type === 'client' ? item.id : item.project_id %>" 
                      data-type="<%= item.type %>" 
                      <%= item.type === 'project' ? `data-client-id=${item.client_id}` : '' %> >
                <i class="fa-solid fa-arrow-rotate-left"></i> Restore
              </button>
              <button class="action-btn delete-btn" data-id="<%= item.type === 'client' ? item.id : item.project_id %>" data-type="<%= item.type %>">
                <i class="fa-solid fa-trash-can"></i> Delete Forever
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p>No items in trash.</p>
    <% } %>
  </div>
</div>

<link rel="stylesheet" href="/css/trash.css">
<script src="/js/trash.js"></script>

</body>
</html>