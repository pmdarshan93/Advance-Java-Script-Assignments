<%- include ("partials/sidebar")%>
<%- include('partials/chatbot')%>

    <div class="dashboard-container">
        <div class="dashboard-header">
            <div>
                <h1>Dashboard</h1>
                <p>Overview of your token management system</p>
            </div>
            <!-- <button class="theme-btn" title="Toggle theme">☀</button> -->
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">🌐</div>
                    <p>↗</p>
                </div>
                <div class="stat-number" id="total-clients">--</div>
                <div class="stat-label">Total Clients</div>
            </div>
            
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">📋</div>
                    <p>↗</p>
                </div>
                <div class="stat-number" id="total-projects">--</div>
                <div class="stat-label">Total Projects</div>
            </div>
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">✅</div>
                    <p>↗</p>
                </div>
                <div class="stat-number" id="valid-tokens">--</div>
                <div class="stat-label">Valid Tokens</div>
            </div>
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">❌</div>
                    <p>↗</p>
                </div>
                <div class="stat-number" id="expired-tokens">--</div>
                <div class="stat-label">Expired Tokens</div>
            </div>
        </div>

        
        <div class="charts-grid">
            <!-- Bar Chart -->
            <div class="chart-card">
                <div class="chart-title">Token Activity — 7 Days Overview</div>
                <div class="chart-wrapper">
                    <canvas id="barChart"></canvas>
                </div>
                <div class="bar-legend">
                    <div class="bar-legend-item">
                        <div class="bar-legend-box" style="background:#3fb950"></div>
                        Created
                    </div>
                </div>
            </div>
        
            <!-- Pie Chart -->
            <div class="chart-card">
                <div class="chart-title">Token Status Distribution</div>
                <div class="chart-wrapper">
                    <canvas id="pieChart"></canvas>
                </div>
                <div class="pie-legend">
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#3fb950"></div>
                        <span id="pie-valid-label">Valid : --</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#f85149"></div>
                        <span id="pie-expired-label">Expired : --</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="project-per-client-card">
            <h2 class="chart-title">Project Per Client</h2>
            <div id="client-project-list"></div>
        </div>
</body>
</html>