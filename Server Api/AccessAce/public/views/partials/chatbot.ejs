<!-- paste before </body> -->
<div id="chatWidget">

    <div id="chatBox" class="chat-hidden">
        <div id="chatHead">
            <span>Access Ace Bot</span>
            <button id="chatCloseBtn">✕</button>
        </div>

        <div id="chatMessages">
            <div class="msg bot">Hi! Ask me anything about tokens or scopes.</div>
        </div>

        <div id="chatFoot">
            <input id="chatInput" placeholder="Ask something…" autocomplete="off">
            <button id="chatSend">↑</button>
        </div>
    </div>

    <button id="chatToggle">💬 Ask Bot</button>

</div>

<link rel="stylesheet" href="css/chat.css">
<script src="js/chat.js" defer></script>