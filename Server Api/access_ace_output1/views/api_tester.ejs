<%- include('partials/sidebar', { page: 'api_tester' }) %>

        <div id="api_tester_page">

            <!-- ═══ TOP BAR: App + Scope selectors ═══ -->
            <div class="tester-topbar">
                <div class="topbar-left">
                    <h2 class="topbar-title">🧪 API Tester</h2>
                    <p class="topbar-sub">Select an app and scope to explore Zoho APIs</p>
                </div>
                <div class="topbar-selectors">
                    <div class="top-selector-wrap">
                        <label class="top-selector-label">App</label>
                        <select id="app-select" class="top-select">
                            <option value="">— Select Zoho App —</option>
                        </select>
                    </div>
                    <div class="top-selector-wrap" id="scope-group" style="display:none;">
                        <label class="top-selector-label">Scope</label>
                        <select id="scope-select" class="top-select">
                            <option value="">— All Scopes —</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- ═══ BODY: Endpoints sidebar + Panels ═══ -->
            <div class="tester-body">

                <!-- Left: endpoint list -->
                <div class="tester-sidebar">
                    <div class="ep-search-wrap">
                        <input type="text" id="endpoint-search" class="ep-search" placeholder="🔍  Search endpoints…">
                    </div>
                    <div id="endpoint-list" class="endpoint-list">
                        <div class="ep-empty">Select an app above to see endpoints</div>
                    </div>
                </div>

                <!-- Right: request + response panels -->
                <div class="tester-panels">

                    <!-- REQUEST -->
                    <div class="tester-panel">
                        <div class="panel-header">
                            <h3>Request</h3>
                            <span id="scope-badge" class="scope-badge" style="display:none;"></span>
                        </div>

                        <div class="url-row">
                            <select id="req-method" class="method-select">
                                <option>GET</option>
                                <option>POST</option>
                                <option>PUT</option>
                                <option>PATCH</option>
                                <option>DELETE</option>
                            </select>
                            <input type="text" id="req-url" class="url-input" placeholder="https://www.zohoapis.com/…">
                        </div>

                        <div class="field-group">
                            <label class="field-label">Access Token</label>
                            <div class="token-row">
                                <input type="text" id="req-token" class="tester-input" placeholder="Paste your Zoho OAuth access token">
                                <button class="icon-btn" onclick="copyField('req-token')">⎘</button>
                            </div>
                        </div>

                        <div class="tab-bar" id="req-tab-bar">
                            <button class="tab-btn active" data-tab="params">Params</button>
                            <button class="tab-btn" data-tab="headers">Headers</button>
                            <button class="tab-btn" data-tab="body">Body</button>
                        </div>

                        <div id="req-tab-params" class="tab-pane active">
                            <textarea id="req-params" class="tester-textarea" placeholder="{}"></textarea>
                            <button class="icon-btn copy-ta" onclick="copyField('req-params')">⎘ Copy</button>
                        </div>
                        <div id="req-tab-headers" class="tab-pane">
                            <textarea id="req-headers" class="tester-textarea" placeholder='{"Content-Type":"application/json"}'></textarea>
                            <button class="icon-btn copy-ta" onclick="copyField('req-headers')">⎘ Copy</button>
                        </div>
                        <div id="req-tab-body" class="tab-pane">
                            <textarea id="req-body" class="tester-textarea" placeholder="null"></textarea>
                            <button class="icon-btn copy-ta" onclick="copyField('req-body')">⎘ Copy</button>
                        </div>

                        <button id="send-btn" onclick="sendRequest()">
                            <span id="send-spinner" style="display:none;">⟳ </span>Send Request
                        </button>
                    </div>

                    <!-- RESPONSE -->
                    <div class="tester-panel">
                        <div class="panel-header">
                            <h3>Response</h3>
                            <div id="res-meta" style="display:none;" class="res-meta-row">
                                <span id="res-status" class="res-status-badge"></span>
                                <span id="res-time" class="res-meta-chip"></span>
                                <span id="res-size" class="res-meta-chip"></span>
                            </div>
                        </div>

                        <div class="tab-bar" id="res-tab-bar">
                            <button class="tab-btn active" data-tab="res-body">Body</button>
                            <button class="tab-btn" data-tab="res-hdrs">Headers</button>
                        </div>

                        <div id="res-tab-res-body" class="tab-pane active">
                            <div id="res-body-wrap" class="res-body-wrap">
                                <div class="res-empty-state">Send a request to see the response here.</div>
                            </div>
                            <button class="icon-btn copy-ta" id="copy-res-btn" onclick="copyResBody()" style="display:none;">⎘ Copy</button>
                        </div>
                        <div id="res-tab-res-hdrs" class="tab-pane">
                            <div id="res-hdrs-wrap" class="res-body-wrap">
                                <div class="res-empty-state">No response yet.</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div><!-- /.container -->

    <script src="js/zohoData.js"></script>
    <script src="js/apiTester.js"></script>
</body>
</html>
