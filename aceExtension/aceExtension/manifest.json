{
    "name": "ACCESSACE",
    "version": "1.0",
    "manifest_version": 3,
    "description": "Access Token Management",
    "permissions": [
        "storage",
        "identity",
        "clipboardWrite"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "128": "logo1.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "https://accounts.zoho.in/*"
    ]
}