{
    "manifest_version" : 3,
    "name" : "Password Manager",
    "version" : "2",
    "action" : {
        "default_popup" : "pop.html"
    },
    "background" : {
        "service_worker" : "background.js"
    },
    "permissions" : [
        "storage"
    ],
    "content_scripts": [{
        "matches" : ["<all_urls>"],
        "js" : ["content.js"]
    }]
}